# NEW: src-tauri/src/cli_server/handlers/companion.rs
# ============================================================================
# Three handlers: pair, list_devices, revoke_device.

use std::sync::Arc;
use chrono::Utc;
use http_body_util::Full;
use hyper::body::Bytes;
use hyper::{header::CONTENT_TYPE, Response, StatusCode};
use uuid::Uuid;
use crate::companion::{
    keys::RootKey,
    pairing::{burn_one_shot, BurnError},
    store::{PairedDevice, PairedDeviceStore},
    wire::{PairRequest, PairResponse},
};
use crate::cli_server::{error::IpcError, IpcCtx};

pub async fn pair(ctx: &Arc<IpcCtx>, body: &Bytes) -> Result<Response<Full<Bytes>>, IpcError> {
    let req: PairRequest = serde_json::from_slice(body)
        .map_err(|e| IpcError::ValidationError(format!("invalid pair body: {e}")))?;

    burn_one_shot(&ctx.pending_pairings, &req.one_shot_token).map_err(|e| match e {
        BurnError::NotFound => IpcError::PairingBurned,
        BurnError::Expired  => IpcError::PairingExpired,
        BurnError::StorePoisoned => IpcError::Internal("pending store poisoned".into()),
    })?;

    let device_id = Uuid::new_v4().to_string();
    let fpr = sha256_fingerprint(&req.device_pubkey);
    ctx.paired_store.insert(PairedDevice {
        device_id: device_id.clone(),
        label: req.device_label,
        pubkey_fingerprint: fpr.clone(),
        paired_at: Utc::now(),
        last_seen_at: Utc::now(),
        revoked: false,
    }).map_err(IpcError::Internal)?;

    let device_key = ctx.root_key.derive_device_key(&device_id);
    let resp = PairResponse {
        device_id,
        device_pairing_key: device_key.to_hex(),
        server_pubkey_fingerprint: ctx.root_key.fingerprint(),
    };
    json_response(StatusCode::OK, &resp)
}

pub async fn list_devices(ctx: &Arc<IpcCtx>) -> Result<Response<Full<Bytes>>, IpcError> {
    json_response(StatusCode::OK, &ctx.paired_store.list())
}

pub async fn revoke_device(ctx: &Arc<IpcCtx>, id: &str) -> Result<Response<Full<Bytes>>, IpcError> {
    ctx.paired_store.revoke(id).map_err(|_| IpcError::NotFound)?;
    json_response(StatusCode::OK, &serde_json::json!({ "revoked": true }))
}

# ============================================================================
# WebSocket upgrade
# ============================================================================
# tokio-tungstenite 0.21 integrates with hyper 1.x. Add to Cargo.toml under
# the same `companion-pairing` feature:
#
#   tokio-tungstenite = { version = "0.21", optional = true }
#   futures-util = { version = "0.3", optional = true }
#   sha1 = { version = "0.10", optional = true }   # for Sec-WebSocket-Accept
#
# In accept_loop (cli_server/mod.rs), BEFORE dispatch:
#
#   if is_websocket_upgrade(&req) && path == /v1/meeting/{id}/stream {
#       1. verify Authorization: Bearer <hex> against
#          companion::tokens::verify_meeting_token(...).
#       2. respond 101 Switching Protocols with the Sec-WebSocket-Accept
#          handshake.
#       3. yield the upgraded stream to a per-meeting handler that:
#          - reads Opus binary frames -> pushes into the existing
#            audio::pipeline (cpal-fed in main.rs) as raw PCM after
#            decode (opus-decoder crate is already in tree from AIZ-37).
#          - emits GraphDiff text frames whenever the meeting graph
#            changes (subscribes to the existing meeting event bus
#            in meetings.rs).
#       4. on revoke, the handler's next per-frame is_active() check
#          fails and it sends Close 1008 to the phone.
