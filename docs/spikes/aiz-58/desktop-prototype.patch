# Two new error codes for pairing.

  pub enum IpcError {
      AuthRequired,
      AuthInvalid,
      NotFound,
      ValidationError(String),
      IdInvalid(String),
      Conflict(String),
      MethodNotAllowed,
      Internal(String),
+     /// One-shot pairing token unknown or already burned.
+     PairingBurned,
+     /// One-shot pairing token expired.
+     PairingExpired,
  }

# Status mapping:
+ IpcError::PairingBurned  => StatusCode::FORBIDDEN,
+ IpcError::PairingExpired => StatusCode::FORBIDDEN,

# Code mapping:
+ IpcError::PairingBurned  => "pairing_burned",
+ IpcError::PairingExpired => "pairing_expired",

# ============================================================================
# src-tauri/src/cli_server/routes.rs
# ============================================================================
# /v1/pair is unauth (gated by the one-shot token). Everything else uses
# the existing bearer-token gate.

# In `is_status_route` (or a new `is_unauth_route`):
- fn is_status_route(_method: &Method, segments: &[&str]) -> bool {
-     segments == ["v1", "app", "status"]
- }
+ fn is_unauth_route(_method: &Method, segments: &[&str]) -> bool {
+     segments == ["v1", "app", "status"]
+         || segments == ["v1", "pair"]      // gated by one-shot token instead
+ }

# In the route match:
+ #[cfg(feature = "companion-pairing")]
+ (Method::POST, ["pair"]) => handlers::companion::pair(ctx, &body).await,
+ #[cfg(feature = "companion-pairing")]
+ (_, ["pair"]) => Err(IpcError::MethodNotAllowed),
+
+ #[cfg(feature = "companion-pairing")]
+ (Method::GET, ["devices"]) => handlers::companion::list_devices(ctx).await,
+ #[cfg(feature = "companion-pairing")]
+ (_, ["devices"]) => Err(IpcError::MethodNotAllowed),
+
+ #[cfg(feature = "companion-pairing")]
+ (Method::DELETE, ["devices", id]) => handlers::companion::revoke_device(ctx, id).await,
+ #[cfg(feature = "companion-pairing")]
+ (_, ["devices", _]) => Err(IpcError::MethodNotAllowed),
+
+ // WebSocket upgrade — handled OUT OF BAND of the normal dispatcher.
+ // The dispatcher checks for `Upgrade: websocket` before calling
+ // `dispatch`; if present and path matches, hand off to ws_upgrade().
+ // See cli_server/mod.rs accept_loop change below.

