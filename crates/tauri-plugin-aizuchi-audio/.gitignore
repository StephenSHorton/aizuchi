# Cargo build artifacts
/target/
/Cargo.lock

# Swift Package Manager build artifacts (created by IDE indexing of ios/Package.swift)
/ios/.build/
/ios/.swiftpm/

# The `permissions/autogenerated/` directory is regenerated by build.rs on
# every compile, but committing the contents keeps PR reviews honest about
# what commands the plugin exposes. The build script overwrites them
# idempotently, so a stale checked-in copy is harmless.
